enum HealthSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum HealthCategory {
  IMPORT
  INTEGRATION
  AUTOMATION
  AUTH
  STORAGE
  BILLING
  UNKNOWN
}


  requestedById String
  type          DataExportType
  status        DataExportStatus @default(REQUESTED)
  fileAssetId   String?
  expiresAt     DateTime?
  reason        String?
  createdAt     DateTime         @default(now())
  completedAt   DateTime?

  @@index([tenantId])
  @@index([tenantId, status])
}

enum DataDeletionType {
  CUSTOMER_DATA
  TENANT_DATA
}

enum DataDeletionStatus {
  REQUESTED
  APPROVED
  REJECTED
  PROCESSING
  COMPLETED
  FAILED
}

model DataDeletionRequest {

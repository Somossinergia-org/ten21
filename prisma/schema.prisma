generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// TENANT (TIENDA)
// ============================================================
model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  active    Boolean  @default(true)
  planCode  String?
  trialEndsAt DateTime?
  suspendedAt DateTime?
  suspensionReason String?
  billingStatusSnapshot String?
  complianceStatusSnapshot String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  products       Product[]
  suppliers      Supplier[]
  purchaseOrders PurchaseOrder[]
  receptions     Reception[]
  incidents      Incident[]
  vehicles       Vehicle[]
  deliveries     Delivery[]
  activityLogs   ActivityLog[]
  attachments    Attachment[]
  customers      Customer[]
  notifications  Notification[]
  salesOrders    SalesOrder[]
  stockMovements StockMovement[]
  postSaleTickets PostSaleTicket[]
  customerInvoices  CustomerInvoice[]
  treasuryEntries   TreasuryEntry[]
  fileAssets        FileAsset[]
  deliveryProofs    DeliveryProof[]
  outboundMessages  OutboundMessage[]
  automationRules   AutomationRule[]
  notifTemplates    NotificationTemplate[]
  tenantConfig      TenantConfig?
  tenantBranding    TenantBranding?
  tenantModules     TenantModule[]
  tenantTemplates   TenantTemplate[]
  importJobs        ImportJob[]
  tenantOnboarding  TenantOnboarding?
  featureFlags      FeatureFlag[]
  supportCases      SupportCase[]
  healthEvents      SystemHealthEvent[]
  subscription      TenantSubscription?
  billingInvoices   BillingInvoice[]
  usageMetrics      UsageMetric[]
  billingEvents     BillingEvent[]
  dataExports       DataExportRequest[]
  dataDeletions     DataDeletionRequest[]
  securityEvents    SecurityEvent[]
  backupJobs        BackupJob[]
}

// ============================================================
// USUARIOS Y ROLES
// ============================================================
enum Role {
  JEFE
  ALMACEN
  REPARTO
}

model User {
  id        String   @id @default(cuid())
  email     String
  name      String
  password  String
  role      Role     @default(ALMACEN)
  active    Boolean  @default(true)
  lastLoginAt      DateTime?
  failedLoginCount Int      @default(0)
  lockedUntil      DateTime?
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchases          PurchaseOrder[]
  receptions         Reception[]
  reportedIncidents  Incident[]  @relation("incidentReportedBy")
  closedIncidents    Incident[]  @relation("incidentClosedBy")
  assignedDeliveries Delivery[]
  salesOrders        SalesOrder[]
  createdTickets     PostSaleTicket[] @relation("ticketCreatedBy")
  assignedTickets    PostSaleTicket[] @relation("ticketAssignedTo")
  customerInvoices   CustomerInvoice[]

  @@unique([tenantId, email])
  @@index([tenantId])
}

// ============================================================
// PRODUCTOS
// ============================================================
model Product {
  id          String   @id @default(cuid())
  ref         String
  name        String
  description String?
  salePrice   Decimal?          // Precio de venta al público
  defaultCost Decimal?          // Coste por defecto para margen estimado
  category    String?           // Familia/categoría (texto libre)
  brand       String?           // Marca del producto
  active      Boolean  @default(true)
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  purchaseLines  PurchaseOrderLine[]
  deliveryLines  DeliveryLine[]
  salesLines     SalesOrderLine[]
  inventory      ProductInventory?
  stockMovements StockMovement[]

  @@unique([tenantId, ref])
  @@index([tenantId])
}

// ============================================================
// PROVEEDORES
// ============================================================
model Supplier {
  id              String   @id @default(cuid())
  name            String
  code            String
  phone           String?
  email           String?
  taxId           String?           // CIF/NIF del proveedor
  commercialTerms String?           // Condiciones comerciales
  paymentTerms    String?           // Condiciones de pago
  notes           String?
  active          Boolean  @default(true)
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  orders   PurchaseOrder[]
  invoices SupplierInvoice[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

// ============================================================
// FLUJO DE ENTRADA: PEDIDOS A PROVEEDOR
// ============================================================
enum PurchaseStatus {
  DRAFT
  SENT
  PARTIAL
  RECEIVED
  CLOSED
}

enum PurchaseOrderType {
  SALE
  EXHIBITION
}

model PurchaseOrder {
  id          String            @id @default(cuid())
  orderNumber String
  type        PurchaseOrderType @default(SALE)
  supplierId  String
  supplier    Supplier          @relation(fields: [supplierId], references: [id])
  status      PurchaseStatus    @default(DRAFT)
  notes       String?
  tenantId    String
  tenant      Tenant            @relation(fields: [tenantId], references: [id])
  createdById String
  createdBy   User              @relation(fields: [createdById], references: [id])
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  lines      PurchaseOrderLine[]
  receptions Reception[]
  invoices   SupplierInvoice[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([tenantId, status])
}

model PurchaseOrderLine {
  id               String        @id @default(cuid())
  purchaseOrderId  String
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId        String
  product          Product       @relation(fields: [productId], references: [id])
  quantityOrdered  Int
  quantityReceived Int           @default(0)
  expectedUnitCost Decimal?

  receptionLines ReceptionLine[]
}

// ============================================================
// FLUJO DE ENTRADA: RECEPCION (ALBARAN)
// ============================================================
enum ReceptionStatus {
  PENDING
  CHECKING
  COMPLETED
  WITH_INCIDENTS
}

model Reception {
  id              String          @id @default(cuid())
  receptionNumber String
  purchaseOrderId String
  purchaseOrder   PurchaseOrder   @relation(fields: [purchaseOrderId], references: [id])
  deliveryNoteRef String?
  status          ReceptionStatus @default(PENDING)
  receivedById    String
  receivedBy      User            @relation(fields: [receivedById], references: [id])
  receivedAt      DateTime        @default(now())
  notes           String?
  tenantId        String
  tenant          Tenant          @relation(fields: [tenantId], references: [id])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  lines     ReceptionLine[]
  incidents Incident[]

  @@unique([tenantId, receptionNumber])
  @@index([tenantId])
  @@index([tenantId, status])
}

model ReceptionLine {
  id                  String            @id @default(cuid())
  receptionId         String
  reception           Reception         @relation(fields: [receptionId], references: [id], onDelete: Cascade)
  purchaseOrderLineId String
  purchaseOrderLine   PurchaseOrderLine @relation(fields: [purchaseOrderLineId], references: [id])
  quantityExpected    Int
  quantityReceived    Int
  quantityDamaged     Int               @default(0)
  notes               String?

  @@unique([receptionId, purchaseOrderLineId])
}

// ============================================================
// INCIDENCIAS
// ============================================================
enum IncidentStatus {
  REGISTERED
  NOTIFIED
  REVIEWED
  CLOSED
}

enum IncidentType {
  QUANTITY_MISMATCH
  DAMAGED
  WRONG_PRODUCT
  OTHER
}

model Incident {
  id           String         @id @default(cuid())
  receptionId  String
  reception    Reception      @relation(fields: [receptionId], references: [id])
  type         IncidentType
  status       IncidentStatus @default(REGISTERED)
  description  String
  resolution   String?
  reviewedAt   DateTime?
  closedAt     DateTime?
  closedById   String?
  closedBy     User?          @relation("incidentClosedBy", fields: [closedById], references: [id])
  reportedById String
  reportedBy   User           @relation("incidentReportedBy", fields: [reportedById], references: [id])
  tenantId     String
  tenant       Tenant         @relation(fields: [tenantId], references: [id])
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
}

// ============================================================
// FLUJO DE SALIDA: VEHICULOS Y ENTREGAS
// ============================================================
enum VehicleStatus {
  AVAILABLE
  IN_USE
  INCIDENT
  WORKSHOP
}

enum DeliveryStatus {
  PENDING
  ASSIGNED
  IN_TRANSIT
  DELIVERED
  FAILED
}

model Vehicle {
  id           String        @id @default(cuid())
  plate        String
  name         String
  status       VehicleStatus @default(AVAILABLE)
  active       Boolean       @default(true)
  externalId   String?
  lastSyncedAt DateTime?
  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  deliveries Delivery[]

  @@unique([tenantId, plate])
  @@unique([tenantId, externalId])
  @@index([tenantId])
  @@index([tenantId, status])
}

model Delivery {
  id              String         @id @default(cuid())
  deliveryNumber  String
  vehicleId       String?
  vehicle         Vehicle?       @relation(fields: [vehicleId], references: [id])
  assignedToId    String?
  assignedTo      User?          @relation(fields: [assignedToId], references: [id])
  customerId      String?
  customer        Customer?      @relation(fields: [customerId], references: [id])
  salesOrderId    String?
  salesOrder      SalesOrder?    @relation(fields: [salesOrderId], references: [id])
  customerName    String         // Mantenido para compatibilidad con datos existentes
  customerPhone   String?
  customerAddress String
  description     String
  status          DeliveryStatus @default(PENDING)
  scheduledDate   DateTime?
  deliveredAt     DateTime?
  startKm         Int?
  endKm           Int?
  failedReason    String?
  proofRequired   Boolean        @default(false)
  notes           String?
  tenantId        String
  tenant          Tenant         @relation(fields: [tenantId], references: [id])
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  lines           DeliveryLine[]
  postSaleTickets PostSaleTicket[]
  proofs          DeliveryProof[]

  @@unique([tenantId, deliveryNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([assignedToId])
  @@index([customerId])
  @@index([salesOrderId])
}

// ============================================================
// ACTIVITY LOG — Auditoría completa de acciones del usuario
// ============================================================
model ActivityLog {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  userId    String?
  userName  String?
  action    String
  entity    String
  entityId  String?
  entityRef String?
  details   Json?
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([tenantId, entity, entityId])
  @@index([tenantId, userId])
}

// ============================================================
// ATTACHMENTS — Documentos adjuntos a cualquier entidad
// ============================================================
enum AttachmentEntity {
  PURCHASE_ORDER
  RECEPTION
  INCIDENT
  DELIVERY
}

model Attachment {
  id          String           @id @default(cuid())
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  entity      AttachmentEntity
  entityId    String
  fileName    String
  fileType    String
  fileSize    Int
  dataUrl     String           @db.Text
  uploadedById String
  uploadedByName String
  notes       String?
  createdAt   DateTime         @default(now())

  @@index([tenantId, entity, entityId])
  @@index([tenantId, createdAt])
}

// ============================================================
// FACTURAS DE PROVEEDOR
// ============================================================
enum InvoiceStatus {
  PENDING    // Pendiente de revision
  VALIDATED  // Validada (cuadra con pedido)
  MISMATCH   // No cuadra (diferencia de importe)
  PAID       // Pagada
}

enum ReconciliationStatus {
  NOT_CHECKED
  MATCHED
  MISMATCHED
}

model SupplierInvoice {
  id                   String                @id @default(cuid())
  invoiceNumber        String?
  supplierId           String?
  supplier             Supplier?             @relation(fields: [supplierId], references: [id])
  supplierName         String?
  supplierNif          String?
  purchaseOrderId      String?
  purchaseOrder        PurchaseOrder?        @relation(fields: [purchaseOrderId], references: [id])
  concept              String?
  baseAmount           Decimal?
  taxAmount            Decimal?
  totalAmount          Decimal?
  taxRate              Decimal?
  invoiceDate          DateTime?
  dueDate              DateTime?
  status               InvoiceStatus         @default(PENDING)
  paidDate             DateTime?
  varianceAmount       Decimal?
  reconciliationStatus ReconciliationStatus  @default(NOT_CHECKED)
  mismatchReason       String?
  pdfDataUrl           String?               @db.Text
  extractedData        Json?
  notes                String?
  tenantId             String
  createdById          String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, dueDate])
}

// ============================================================
// CLIENTES
// ============================================================
model Customer {
  id           String   @id @default(cuid())
  fullName     String
  phone        String?
  email        String?
  addressLine1 String
  addressLine2 String?
  city         String?
  postalCode   String?
  province     String?
  notes            String?
  allowEmail       Boolean  @default(false)
  allowWhatsApp    Boolean  @default(false)
  preferredChannel String?
  active           Boolean  @default(true)
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  deliveries       Delivery[]
  salesOrders      SalesOrder[]
  postSaleTickets  PostSaleTicket[]
  customerInvoices CustomerInvoice[]

  @@index([tenantId])
  @@index([tenantId, fullName])
}

// ============================================================
// LINEAS DE ENTREGA
// ============================================================
model DeliveryLine {
  id          String   @id @default(cuid())
  deliveryId  String
  delivery    Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  description String
  quantity    Int      @default(1)
  notes       String?
  tenantId    String
  createdAt   DateTime @default(now())

  @@index([deliveryId])
  @@index([tenantId])
}

// ============================================================
// NOTIFICACIONES INTERNAS
// ============================================================
enum NotificationType {
  INCIDENT_CREATED
  DELIVERY_FAILED
  ORDER_PARTIAL
  INVOICE_MISMATCH
  SYSTEM
}

enum NotificationSeverity {
  LOW
  MEDIUM
  HIGH
}

model Notification {
  id         String               @id @default(cuid())
  tenantId   String
  tenant     Tenant               @relation(fields: [tenantId], references: [id])
  type       NotificationType
  title      String
  message    String
  severity   NotificationSeverity @default(MEDIUM)
  entityType String?
  entityId   String?
  userId     String?              // Destinatario (null = todos del tenant)
  readAt     DateTime?
  createdAt  DateTime             @default(now())

  @@index([tenantId, userId, readAt])
  @@index([tenantId, createdAt])
}

// ============================================================
// VENTAS (SALES ORDERS)
// ============================================================
enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  PARTIALLY_RESERVED
  RESERVED
  IN_DELIVERY
  DELIVERED
  CANCELLED
}

model SalesOrder {
  id                    String           @id @default(cuid())
  orderNumber           String
  customerId            String
  customer              Customer         @relation(fields: [customerId], references: [id])
  status                SalesOrderStatus @default(DRAFT)
  notes                 String?
  scheduledDeliveryDate DateTime?
  subtotal              Decimal          @default(0)
  discountTotal         Decimal          @default(0)
  total                 Decimal          @default(0)
  estimatedMargin       Decimal?
  realMargin            Decimal?
  paymentStatus         String?          @default("UNBILLED") // UNBILLED, BILLED, PARTIALLY_PAID, PAID
  createdById           String
  createdBy             User             @relation(fields: [createdById], references: [id])
  confirmedAt           DateTime?
  deliveredAt           DateTime?
  tenantId              String
  tenant                Tenant           @relation(fields: [tenantId], references: [id])
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  lines            SalesOrderLine[]
  deliveries       Delivery[]
  postSaleTickets  PostSaleTicket[]
  customerInvoices CustomerInvoice[]

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([customerId])
}

model SalesOrderLine {
  id               String     @id @default(cuid())
  salesOrderId     String
  salesOrder       SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  productId        String?
  product          Product?   @relation(fields: [productId], references: [id])
  description      String
  quantity         Int
  unitSalePrice    Decimal
  unitExpectedCost Decimal?
  lineTotal        Decimal
  notes            String?
  tenantId         String

  @@index([salesOrderId])
}

// ============================================================
// INVENTARIO LIGERO
// ============================================================
model ProductInventory {
  id        String   @id @default(cuid())
  productId String   @unique
  product   Product  @relation(fields: [productId], references: [id])
  tenantId  String
  onHand    Int      @default(0)
  reserved  Int      @default(0)
  available Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([tenantId, productId])
  @@index([tenantId])
}

enum StockMovementType {
  RECEPTION_IN
  SALE_RESERVE
  SALE_RELEASE
  DELIVERY_OUT
  MANUAL_ADJUSTMENT
}

model StockMovement {
  id            String            @id @default(cuid())
  tenantId      String
  tenant        Tenant            @relation(fields: [tenantId], references: [id])
  productId     String
  product       Product           @relation(fields: [productId], references: [id])
  type          StockMovementType
  quantity      Int
  referenceType String?
  referenceId   String?
  notes         String?
  performedById String?
  createdAt     DateTime          @default(now())

  @@index([tenantId, productId])
  @@index([tenantId, createdAt])
  @@index([referenceType, referenceId])
}

// ============================================================
// POSVENTA
// ============================================================
enum PostSaleTicketType {
  DAMAGE
  MISSING_ITEM
  INSTALLATION
  WARRANTY
  RETURN
  OTHER
}

enum PostSaleTicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum PostSaleTicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_SUPPLIER
  RESOLVED
  CLOSED
}

model PostSaleTicket {
  id            String                 @id @default(cuid())
  ticketNumber  String
  customerId    String
  customer      Customer               @relation(fields: [customerId], references: [id])
  salesOrderId  String?
  salesOrder    SalesOrder?            @relation(fields: [salesOrderId], references: [id])
  deliveryId    String?
  delivery      Delivery?              @relation(fields: [deliveryId], references: [id])
  type          PostSaleTicketType
  priority      PostSaleTicketPriority @default(NORMAL)
  status        PostSaleTicketStatus   @default(OPEN)
  description   String
  resolution    String?
  createdById   String
  createdBy     User                   @relation("ticketCreatedBy", fields: [createdById], references: [id])
  assignedToId  String?
  assignedTo    User?                  @relation("ticketAssignedTo", fields: [assignedToId], references: [id])
  resolvedAt    DateTime?
  closedAt      DateTime?
  tenantId      String
  tenant        Tenant                 @relation(fields: [tenantId], references: [id])
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@unique([tenantId, ticketNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([customerId])
}

// ============================================================
// FACTURACION CLIENTE (V4)
// ============================================================
enum CustomerInvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  CANCELLED
}

model CustomerInvoice {
  id             String                @id @default(cuid())
  invoiceNumber  String
  customerId     String
  customer       Customer              @relation(fields: [customerId], references: [id])
  salesOrderId   String?
  salesOrder     SalesOrder?           @relation(fields: [salesOrderId], references: [id])
  status         CustomerInvoiceStatus @default(DRAFT)
  issueDate      DateTime?
  dueDate        DateTime?
  subtotal       Decimal               @default(0)
  taxAmount      Decimal               @default(0)
  total          Decimal               @default(0)
  paidAmount     Decimal               @default(0)
  paidAt         DateTime?
  notes          String?
  createdById    String
  createdBy      User                  @relation(fields: [createdById], references: [id])
  tenantId       String
  tenant         Tenant                @relation(fields: [tenantId], references: [id])
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  lines CustomerInvoiceLine[]

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([customerId])
}

model CustomerInvoiceLine {
  id                String          @id @default(cuid())
  customerInvoiceId String
  customerInvoice   CustomerInvoice @relation(fields: [customerInvoiceId], references: [id], onDelete: Cascade)
  salesOrderLineId  String?
  description       String
  quantity          Int
  unitPrice         Decimal
  taxRate           Decimal         @default(21)
  lineSubtotal      Decimal
  lineTax           Decimal
  lineTotal         Decimal
  tenantId          String

  @@index([customerInvoiceId])
}

// ============================================================
// TESORERIA (V4)
// ============================================================
enum TreasuryType {
  INCOME_EXPECTED
  INCOME_CONFIRMED
  EXPENSE_EXPECTED
  EXPENSE_CONFIRMED
}

enum TreasuryStatus {
  PENDING
  UPCOMING
  PAID
  OVERDUE
  CANCELLED
}

model TreasuryEntry {
  id          String         @id @default(cuid())
  tenantId    String
  tenant      Tenant         @relation(fields: [tenantId], references: [id])
  type        TreasuryType
  sourceType  String?        // SUPPLIER_INVOICE, CUSTOMER_INVOICE, MANUAL
  sourceId    String?
  category    String?
  concept     String
  amount      Decimal
  dueDate     DateTime?
  paidDate    DateTime?
  status      TreasuryStatus @default(PENDING)
  notes       String?
  createdById String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, dueDate])
  @@index([sourceType, sourceId])
}

// ============================================================
// FILE STORAGE (V5)
// ============================================================
model FileAsset {
  id               String   @id @default(cuid())
  tenantId         String
  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  provider         String   @default("local") // local, vercel-blob, s3
  storageKey       String
  publicUrl        String?  @db.Text
  mimeType         String
  fileName         String
  fileSize         Int
  checksum         String?
  uploadedById     String?
  createdAt        DateTime @default(now())

  deliveryProofs DeliveryProof[]

  @@index([tenantId])
}

// ============================================================
// PRUEBAS DE ENTREGA (V5)
// ============================================================
enum DeliveryProofType {
  PHOTO
  SIGNATURE
  GPS_SNAPSHOT
  NOTE
}

model DeliveryProof {
  id           String            @id @default(cuid())
  tenantId     String
  tenant       Tenant            @relation(fields: [tenantId], references: [id])
  deliveryId   String
  delivery     Delivery          @relation(fields: [deliveryId], references: [id])
  type         DeliveryProofType
  fileAssetId  String?
  fileAsset    FileAsset?        @relation(fields: [fileAssetId], references: [id])
  note         String?
  latitude     Decimal?
  longitude    Decimal?
  capturedAt   DateTime          @default(now())
  capturedById String?
  requestId    String?           // Idempotency key from offline sync
  createdAt    DateTime          @default(now())

  @@index([deliveryId])
  @@index([tenantId])
  @@index([requestId])
}

// ============================================================
// DEVICE SUBSCRIPTIONS — Web Push (V5)
// ============================================================
model DeviceSubscription {
  id          String    @id @default(cuid())
  tenantId    String
  userId      String
  endpoint    String    @db.Text
  p256dh      String
  auth        String
  deviceLabel String?
  active      Boolean   @default(true)
  lastSeenAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, endpoint])
  @@index([tenantId, userId])
}

// ============================================================
// PLANTILLAS DE NOTIFICACION (V5)
// ============================================================
enum MessageChannel {
  INTERNAL
  PUSH
  EMAIL
  WHATSAPP
}

model NotificationTemplate {
  id        String         @id @default(cuid())
  tenantId  String
  tenant    Tenant         @relation(fields: [tenantId], references: [id])
  code      String
  channel   MessageChannel
  eventType String
  subject   String?
  body      String         @db.Text
  active    Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  rules AutomationRule[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

// ============================================================
// REGLAS DE AUTOMATIZACION (V5)
// ============================================================
enum AutomationTarget {
  USER
  CUSTOMER
  ROLE
}

model AutomationRule {
  id             String           @id @default(cuid())
  tenantId       String
  tenant         Tenant           @relation(fields: [tenantId], references: [id])
  code           String
  eventType      String
  channel        MessageChannel
  target         AutomationTarget
  enabled        Boolean          @default(true)
  conditionsJson Json?
  templateId     String?
  template       NotificationTemplate? @relation(fields: [templateId], references: [id])
  createdById    String
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId, eventType])
}

// ============================================================
// COLA DE MENSAJES SALIENTES (V5)
// ============================================================
enum OutboundMessageStatus {
  QUEUED
  PROCESSING
  SENT
  FAILED
  CANCELLED
}

model OutboundMessage {
  id            String                @id @default(cuid())
  tenantId      String
  tenant        Tenant                @relation(fields: [tenantId], references: [id])
  channel       MessageChannel
  targetType    String                // USER, CUSTOMER
  targetId      String?
  destination   String                // email address, phone number, push endpoint
  subject       String?
  body          String                @db.Text
  eventType     String
  sourceType    String?
  sourceId      String?
  status        OutboundMessageStatus @default(QUEUED)
  attempts      Int                   @default(0)
  maxAttempts   Int                   @default(3)
  nextAttemptAt DateTime?
  lastError     String?
  sentAt        DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([status, nextAttemptAt])
  @@index([eventType, sourceType, sourceId])
}

